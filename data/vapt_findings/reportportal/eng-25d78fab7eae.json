  "findings": [
    {
      "id": "F-001",
      "scan_id": "scan-d79ea1851bcc",
      "test_id": "tests/vapt_infra/test_vapt_infra_ports.py::test_INFRA_sensitive_service_ports_not_exposed",
      "title": "Sensitive Service Ports Exposed to Network",
      "owasp_ref": "A05",
      "owasp_category": "Security Misconfiguration",
      "severity": "Critical",
      "status": "open",
      "description": "Redis (6379) and MongoDB (27017) ports are directly reachable from the test network, indicating a firewall gap. These data-store services should only be accessible from trusted application-tier subnets. External reachability allows unauthenticated access to databases if default credentials or no auth is configured.",
      "evidence": "socket.create_connection(('localhost', 6379), timeout=2) — connected in 3ms\nsocket.create_connection(('localhost', 27017), timeout=2) — connected in 4ms\nBoth ports respond without authentication challenge.",
      "screenshot_path": null,
      "remediation": "Apply host-based firewall rules to restrict ports 6379 and 27017 to the application server CIDR only.\n\niptables example:\n  iptables -A INPUT -p tcp --dport 6379 -s 10.0.0.0/24 -j ACCEPT\n  iptables -A INPUT -p tcp --dport 6379 -j DROP\n\nAlso enable Redis AUTH (requirepass) and MongoDB SCRAM authentication as defence-in-depth. Verify with: nmap -p 6379,27017 <target> from an external host.",
      "verified_fixed_at": null,
      "revalidation_scan_id": null,
      "created_at": "2026-05-18T11:55:03.781540+00:00"
    },
    {
      "id": "F-002",
      "scan_id": "scan-4a3042eabf32",
      "test_id": "products/reportportal/tests/vapt/test_vapt_rate_limiting.py::test_A04_login_endpoint_rate_limited",
      "title": "No Rate Limiting on Login Endpoint",
      "owasp_ref": "A04",
      "owasp_category": "Insecure Design",
      "severity": "High",
      "status": "still_open",
      "description": "The POST /api/v1/user/login endpoint does not enforce rate limiting or account lockout. An attacker can submit unlimited authentication attempts from a single IP without any throttling, delay, or CAPTCHA challenge. This enables online brute-force and credential-stuffing attacks against all user accounts.",
      "evidence": "Sent 25 sequential POST /api/v1/user/login requests with invalid credentials over 8 seconds.\nAll 25 returned HTTP 401 with no rate-limit headers (no X-RateLimit-*, Retry-After, or 429 response).\nNo lockout triggered after 25 consecutive failures.",
      "screenshot_path": null,
