{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run All Tests",
            "type": "shell",
            "command": "python3",
            "args": ["-m", "pytest", "tests/", "--browser", "chromium", "-v"],
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            }
        },
        {
            "label": "Run API Tests",
            "type": "shell",
            "command": "python3",
            "args": ["-m", "pytest", "tests/api/", "-v"],
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            }
        },
        {
            "label": "Run Web UI Tests",
            "type": "shell",
            "command": "python3",
            "args": ["-m", "pytest", "tests/web/", "--browser", "chromium", "-v"],
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            }
        },
        {
            "label": "Run GraphQL Tests",
            "type": "shell",
            "command": "python3",
            "args": ["-m", "pytest", "tests/api/test_graphql_api.py", "-v"],
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            }
        }
    ]
}