# SentinelFlux — Environment Configuration
# Copy to .env and fill in values. Never commit .env.

# ── Required ───────────────────────────────────────────────────────────────────
# Stable secret for signing session cookies. Generate with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SF_SESSION_SECRET=change_me

# ── AI Providers (at least one required for AI pipeline) ──────────────────────
MISTRAL_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the dashboard API.
SF_ALLOWED_ORIGINS=https://sentinelflux.in

# ── Optional overrides ─────────────────────────────────────────────────────────
# Override the data directory (default: <repo_root>/data).
# Useful if data lives on a separate Hetzner Volume.
# SF_DATA_DIR=/mnt/sfdata
