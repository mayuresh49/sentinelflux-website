{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "data": {
      "type": "object",
      "properties": {
        "country": {
          "type": ["object", "null"],
          "properties": {
            "code": { "type": "string" },
            "name": { "type": "string" },
            "native": { "type": "string" },
            "phone": { "type": "string" },
            "emoji": { "type": "string" },
            "currency": { "type": ["string", "null"] },
            "languages": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "code": { "type": "string" },
                  "name": { "type": "string" },
                  "native": { "type": "string" },
                  "rtl": { "type": "boolean" }
                },
                "required": ["code", "name", "native", "rtl"]
              }
            }
          },
          "required": ["code", "name", "native", "phone", "emoji", "languages"]
        }
      },
      "required": ["country"]
    }
  },
  "required": ["data"]
}
